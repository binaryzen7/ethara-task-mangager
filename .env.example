# PostgreSQL connection string (Railway Postgres plugin provides this)
DATABASE_URL="postgresql://user:password@localhost:5432/team_task_manager?schema=public"

# Secret for JWT session tokens (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-characters"

# Optional: set in production on Railway
NODE_ENV="development"
